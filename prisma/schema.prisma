generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TREASURER
  MEMBER
}

enum MemberStatus {
  ACTIVE
  WARNING
  CLOSED
}

enum StatusMode {
  AUTO
  MANUAL
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmergencyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContributionApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  CONTRIBUTION
  WITHDRAWAL
}

enum StatementType {
  PDF
  IMAGE
}

model User {
  id                String              @id @default(cuid())
  name              String
  username          String              @unique
  email             String              @unique
  passwordHash      String
  role              Role                @default(MEMBER)
  status            MemberStatus        @default(ACTIVE)
  statusMode        StatusMode          @default(AUTO)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  contributions     Contribution[]      @relation("ContributionMember")
  withdrawals       Withdrawal[]        @relation("WithdrawalMember")
  emergencyRequests EmergencyRequest[]  @relation("EmergencyRequestMember")
  createdContribs   Contribution[]      @relation("ContributionActor")
  approvedContribs  Contribution[]      @relation("ContributionApprover")
  rejectedContribs  Contribution[]      @relation("ContributionRejector")
  createdWithdraws  Withdrawal[]        @relation("WithdrawalActor")
  adminApprovedRequests EmergencyRequest[] @relation("EmergencyAdminApprover")
  treasurerApprovedRequests EmergencyRequest[] @relation("EmergencyTreasurerApprover")
  rejectedRequests  EmergencyRequest[]  @relation("EmergencyRejectionActor")
  disbursedRequests EmergencyRequest[]  @relation("EmergencyDisbursementActor")
  transactions      Transaction[]       @relation("TransactionMember")
  actedTransactions Transaction[]       @relation("TransactionActor")
  uploadedStatements BankStatement[]
  uploadedDocuments GoverningDocument[]
  sessions          Session[]
  accounts          Account[]
  resetTokens       PasswordResetToken[]
  targetedStatusChanges MemberStatusChangeRequest[] @relation("MemberStatusChangeTarget")
  requestedStatusChanges MemberStatusChangeRequest[] @relation("MemberStatusChangeRequester")
  adminApprovedStatusChanges MemberStatusChangeRequest[] @relation("MemberStatusChangeAdminApprover")
  treasurerApprovedStatusChanges MemberStatusChangeRequest[] @relation("MemberStatusChangeTreasurerApprover")
  rejectedStatusChanges MemberStatusChangeRequest[] @relation("MemberStatusChangeRejector")
  appliedStatusChanges MemberStatusChangeRequest[] @relation("MemberStatusChangeApplier")

  @@index([role, name])
  @@index([role, status])
}

model CommunitySettings {
  id                 String   @id @default("community")
  warningAfterMonths Int      @default(3)
  closeAfterMonths   Int      @default(6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MemberStatusChangeRequest {
  id                    String              @id @default(cuid())
  memberId              String
  member                User                @relation("MemberStatusChangeTarget", fields: [memberId], references: [id])
  currentStatus         MemberStatus
  requestedStatus       MemberStatus
  status                ChangeRequestStatus @default(PENDING)
  requestedById         String
  requestedBy           User                @relation("MemberStatusChangeRequester", fields: [requestedById], references: [id])
  adminApprovedAt       DateTime?
  adminApprovedById     String?
  adminApprovedBy       User?               @relation("MemberStatusChangeAdminApprover", fields: [adminApprovedById], references: [id])
  treasurerApprovedAt   DateTime?
  treasurerApprovedById String?
  treasurerApprovedBy   User?               @relation("MemberStatusChangeTreasurerApprover", fields: [treasurerApprovedById], references: [id])
  rejectedAt            DateTime?
  rejectedById          String?
  rejectedBy            User?               @relation("MemberStatusChangeRejector", fields: [rejectedById], references: [id])
  appliedAt             DateTime?
  appliedById           String?
  appliedBy             User?               @relation("MemberStatusChangeApplier", fields: [appliedById], references: [id])
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([memberId, status, createdAt])
  @@index([requestedById])
  @@index([adminApprovedById])
  @@index([treasurerApprovedById])
}

model Contribution {
  id               String                     @id @default(cuid())
  memberId         String
  member           User                       @relation("ContributionMember", fields: [memberId], references: [id])
  amount           Decimal                    @db.Decimal(12, 2)
  contributionDate DateTime
  approvalStatus   ContributionApprovalStatus @default(APPROVED)
  createdById      String?
  createdBy        User?                      @relation("ContributionActor", fields: [createdById], references: [id])
  approvedAt       DateTime?
  approvedById     String?
  approvedBy       User?                      @relation("ContributionApprover", fields: [approvedById], references: [id])
  rejectedAt       DateTime?
  rejectedById     String?
  rejectedBy       User?                      @relation("ContributionRejector", fields: [rejectedById], references: [id])
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([memberId, contributionDate])
  @@index([approvalStatus, contributionDate])
  @@index([approvedById])
  @@index([rejectedById])
  @@index([createdAt])
}

model Withdrawal {
  id             String   @id @default(cuid())
  memberId       String
  member         User     @relation("WithdrawalMember", fields: [memberId], references: [id])
  amount         Decimal  @db.Decimal(12, 2)
  reason         String
  withdrawalDate DateTime
  createdById    String?
  createdBy      User?    @relation("WithdrawalActor", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([memberId, withdrawalDate])
  @@index([createdAt])
}

model EmergencyRequest {
  id                    String          @id @default(cuid())
  memberId              String
  member                User            @relation("EmergencyRequestMember", fields: [memberId], references: [id])
  amount                Decimal         @db.Decimal(12, 2)
  approvedAmount        Decimal?        @db.Decimal(12, 2)
  reason                String
  status                EmergencyStatus @default(PENDING)
  requestDate           DateTime        @default(now())
  decisionDate          DateTime?
  adminApprovedAt       DateTime?
  adminApprovedById     String?
  adminApprovedBy       User?           @relation("EmergencyAdminApprover", fields: [adminApprovedById], references: [id])
  treasurerApprovedAt   DateTime?
  treasurerApprovedById String?
  treasurerApprovedBy   User?           @relation("EmergencyTreasurerApprover", fields: [treasurerApprovedById], references: [id])
  rejectedById          String?
  rejectedBy            User?           @relation("EmergencyRejectionActor", fields: [rejectedById], references: [id])
  disbursedAt           DateTime?
  disbursedById         String?
  disbursedBy           User?           @relation("EmergencyDisbursementActor", fields: [disbursedById], references: [id])
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([memberId, requestDate])
  @@index([status, requestDate])
  @@index([adminApprovedById])
  @@index([treasurerApprovedById])
  @@index([rejectedById])
  @@index([disbursedById])
}

model Transaction {
  id         String          @id @default(cuid())
  memberId   String
  member     User            @relation("TransactionMember", fields: [memberId], references: [id])
  type       TransactionType
  amount     Decimal         @db.Decimal(12, 2)
  eventDate  DateTime
  notes      String?
  actorId    String?
  actor      User?           @relation("TransactionActor", fields: [actorId], references: [id])
  createdAt  DateTime        @default(now())

  @@index([memberId, type, eventDate])
  @@index([createdAt])
}

model BankStatement {
  id            String        @id @default(cuid())
  filename      String
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String
  data          Bytes?
  statementType StatementType
  statementDate DateTime?
  statementPeriod String?
  uploadedById  String?
  uploadedBy    User?         @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime      @default(now())

  @@index([createdAt])
}

model GoverningDocument {
  id           String   @id @default(cuid())
  title        String
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  data         Bytes?
  isActive     Boolean  @default(true)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([isActive, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
