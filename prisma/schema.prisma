generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                             String                      @id @default(cuid()) @db.VarChar(191)
  name                           String
  username                       String                      @unique @db.VarChar(255)
  email                          String                      @unique @db.VarChar(255)
  passwordHash                   String
  role                           String                      @default("MEMBER") @db.VarChar(32)
  accessRoleId                   String?                     @db.VarChar(191)
  status                         String                      @default("ACTIVE") @db.VarChar(32)
  createdAt                      DateTime                    @default(now())
  updatedAt                      DateTime                    @updatedAt
  statusMode                     String                      @default("AUTO") @db.VarChar(32)
  accessRole                     AccessRole?                 @relation(fields: [accessRoleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accounts                       Account[]
  uploadedBankStatements         BankStatement[]
  contributionApprovals          Contribution[]              @relation("ContributionApprovedBy")
  contributionsCreated           Contribution[]              @relation("ContributionCreatedBy")
  contributions                  Contribution[]              @relation("ContributionMember")
  contributionRejections         Contribution[]              @relation("ContributionRejectedBy")
  emergencyAdminApprovals        EmergencyRequest[]          @relation("EmergencyRequestAdminApprovedBy")
  emergencyDisbursements         EmergencyRequest[]          @relation("EmergencyRequestDisbursedBy")
  emergencyRequests              EmergencyRequest[]          @relation("EmergencyRequestMember")
  emergencyRejections            EmergencyRequest[]          @relation("EmergencyRequestRejectedBy")
  emergencyTreasurerApprovals    EmergencyRequest[]          @relation("EmergencyRequestTreasurerApprovedBy")
  uploadedDocuments              GoverningDocument[]
  memberStatusAdminApprovals     MemberStatusChangeRequest[] @relation("MemberStatusChangeRequestAdminApprovedBy")
  memberStatusApplications       MemberStatusChangeRequest[] @relation("MemberStatusChangeRequestAppliedBy")
  memberStatusChanges            MemberStatusChangeRequest[] @relation("MemberStatusChangeRequestMember")
  memberStatusRejections         MemberStatusChangeRequest[] @relation("MemberStatusChangeRequestRejectedBy")
  requestedMemberStatusChanges   MemberStatusChangeRequest[] @relation("MemberStatusChangeRequestRequestedBy")
  memberStatusTreasurerApprovals MemberStatusChangeRequest[] @relation("MemberStatusChangeRequestTreasurerApprovedBy")
  passwordResetTokens            PasswordResetToken[]
  sessions                       Session[]
  transactionActions             Transaction[]               @relation("TransactionActor")
  transactions                   Transaction[]               @relation("TransactionMember")
  withdrawalsCreated             Withdrawal[]                @relation("WithdrawalCreatedBy")
  withdrawals                    Withdrawal[]                @relation("WithdrawalMember")

  @@index([role, name])
  @@index([role, status])
  @@index([accessRoleId])
}

model AccessRole {
  id              String                 @id @default(cuid()) @db.VarChar(191)
  key             String                 @unique @db.VarChar(64)
  name            String                 @db.VarChar(128)
  description     String?
  isSystem        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  users           User[]
  rolePermissions AccessRolePermission[]

  @@index([isSystem, name])
}

model Permission {
  id              String                 @id @default(cuid()) @db.VarChar(191)
  key             String                 @unique @db.VarChar(128)
  module          String                 @db.VarChar(64)
  name            String                 @db.VarChar(128)
  description     String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  rolePermissions AccessRolePermission[]

  @@index([module, name])
}

model AccessRolePermission {
  id           String     @id @default(cuid()) @db.VarChar(191)
  roleId       String     @db.VarChar(191)
  permissionId String     @db.VarChar(191)
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role         AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model Contribution {
  id               String    @id @default(cuid()) @db.VarChar(191)
  memberId         String    @db.VarChar(191)
  amount           Decimal   @db.Decimal(12, 2)
  contributionDate DateTime
  createdById      String?   @db.VarChar(191)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  approvalStatus   String    @default("APPROVED") @db.VarChar(32)
  approvedAt       DateTime?
  approvedById     String?   @db.VarChar(191)
  rejectedAt       DateTime?
  rejectedById     String?   @db.VarChar(191)
  approvedBy       User?     @relation("ContributionApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy        User?     @relation("ContributionCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member           User      @relation("ContributionMember", fields: [memberId], references: [id], onUpdate: NoAction)
  rejectedBy       User?     @relation("ContributionRejectedBy", fields: [rejectedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([memberId, contributionDate])
  @@index([createdAt])
  @@index([approvalStatus, contributionDate])
  @@index([approvedById])
  @@index([rejectedById])
}

model Withdrawal {
  id             String   @id @default(cuid()) @db.VarChar(191)
  memberId       String   @db.VarChar(191)
  amount         Decimal  @db.Decimal(12, 2)
  reason         String
  purpose        String   @default("WELFARE") @db.VarChar(32)
  withdrawalDate DateTime
  createdById    String?  @db.VarChar(191)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      User?    @relation("WithdrawalCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member         User     @relation("WithdrawalMember", fields: [memberId], references: [id], onUpdate: NoAction)

  @@index([memberId, withdrawalDate])
  @@index([purpose])
  @@index([createdAt])
}

model EmergencyRequest {
  id                    String    @id @default(cuid()) @db.VarChar(191)
  memberId              String    @db.VarChar(191)
  amount                Decimal   @db.Decimal(12, 2)
  reason                String
  status                String    @default("PENDING") @db.VarChar(32)
  requestDate           DateTime  @default(now())
  decisionDate          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  approvedAmount        Decimal?  @db.Decimal(12, 2)
  adminApprovedAt       DateTime?
  adminApprovedById     String?   @db.VarChar(191)
  treasurerApprovedAt   DateTime?
  treasurerApprovedById String?   @db.VarChar(191)
  rejectedById          String?   @db.VarChar(191)
  disbursedAt           DateTime?
  disbursedById         String?   @db.VarChar(191)
  adminApprovedBy       User?     @relation("EmergencyRequestAdminApprovedBy", fields: [adminApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  disbursedBy           User?     @relation("EmergencyRequestDisbursedBy", fields: [disbursedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member                User      @relation("EmergencyRequestMember", fields: [memberId], references: [id], onUpdate: NoAction)
  rejectedBy            User?     @relation("EmergencyRequestRejectedBy", fields: [rejectedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  treasurerApprovedBy   User?     @relation("EmergencyRequestTreasurerApprovedBy", fields: [treasurerApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([memberId, requestDate])
  @@index([status, requestDate])
  @@index([adminApprovedById])
  @@index([treasurerApprovedById])
  @@index([rejectedById])
  @@index([disbursedById])
}

model Transaction {
  id        String   @id @default(cuid()) @db.VarChar(191)
  memberId  String   @db.VarChar(191)
  type      String   @db.VarChar(32)
  amount    Decimal  @db.Decimal(12, 2)
  eventDate DateTime
  notes     String?
  actorId   String?  @db.VarChar(191)
  createdAt DateTime @default(now())
  actor     User?    @relation("TransactionActor", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member    User     @relation("TransactionMember", fields: [memberId], references: [id], onUpdate: NoAction)

  @@index([memberId, type, eventDate])
  @@index([createdAt])
}

model BankStatement {
  id              String    @id @default(cuid()) @db.VarChar(191)
  filename        String
  originalName    String
  mimeType        String
  sizeBytes       Int
  storagePath     String
  statementType   String    @db.VarChar(32)
  statementDate   DateTime?
  statementPeriod String?
  uploadedById    String?   @db.VarChar(191)
  createdAt       DateTime  @default(now())
  data            Bytes?
  uploadedBy      User?     @relation(fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt])
}

model GoverningDocument {
  id           String   @id @default(cuid()) @db.VarChar(191)
  title        String
  filename     String
  originalName String
  mimeType     String
  storagePath  String
  isActive     Boolean  @default(true)
  uploadedById String?  @db.VarChar(191)
  createdAt    DateTime @default(now())
  sizeBytes    Int
  data         Bytes?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([isActive, createdAt])
}

model CommunitySettings {
  id                 String   @id @default("community") @db.VarChar(191)
  warningAfterMonths Int      @default(3)
  closeAfterMonths   Int      @default(6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid()) @db.VarChar(191)
  token     String    @unique @db.VarChar(255)
  userId    String    @db.VarChar(191)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, expiresAt])
}

model Account {
  id                String  @id @default(cuid()) @db.VarChar(191)
  userId            String  @db.VarChar(191)
  type              String
  provider          String  @db.VarChar(255)
  providerAccountId String  @db.VarChar(255)
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @db.VarChar(191)
  sessionToken String   @unique @db.VarChar(255)
  userId       String   @db.VarChar(191)
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, expires])
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime

  @@unique([identifier, token])
}

model MemberStatusChangeRequest {
  id                    String    @id @default(cuid()) @db.VarChar(191)
  memberId              String    @db.VarChar(191)
  currentStatus         String    @db.VarChar(32)
  requestedStatus       String    @db.VarChar(32)
  status                String    @default("PENDING") @db.VarChar(32)
  requestedById         String    @db.VarChar(191)
  adminApprovedAt       DateTime?
  adminApprovedById     String?   @db.VarChar(191)
  treasurerApprovedAt   DateTime?
  treasurerApprovedById String?   @db.VarChar(191)
  rejectedAt            DateTime?
  rejectedById          String?   @db.VarChar(191)
  appliedAt             DateTime?
  appliedById           String?   @db.VarChar(191)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  adminApprovedBy       User?     @relation("MemberStatusChangeRequestAdminApprovedBy", fields: [adminApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appliedBy             User?     @relation("MemberStatusChangeRequestAppliedBy", fields: [appliedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  member                User      @relation("MemberStatusChangeRequestMember", fields: [memberId], references: [id], onUpdate: NoAction)
  rejectedBy            User?     @relation("MemberStatusChangeRequestRejectedBy", fields: [rejectedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestedBy           User      @relation("MemberStatusChangeRequestRequestedBy", fields: [requestedById], references: [id], onUpdate: NoAction)
  treasurerApprovedBy   User?     @relation("MemberStatusChangeRequestTreasurerApprovedBy", fields: [treasurerApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([memberId, status, createdAt])
  @@index([requestedById])
  @@index([adminApprovedById])
  @@index([treasurerApprovedById])
}
