generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  WARNING
  CLOSED
}

enum EmergencyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  CONTRIBUTION
  WITHDRAWAL
}

enum StatementType {
  PDF
  IMAGE
}

model User {
  id                String              @id @default(cuid())
  name              String
  username          String              @unique
  email             String              @unique
  passwordHash      String
  role              Role                @default(MEMBER)
  status            MemberStatus        @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  contributions     Contribution[]      @relation("ContributionMember")
  withdrawals       Withdrawal[]        @relation("WithdrawalMember")
  emergencyRequests EmergencyRequest[]  @relation("EmergencyRequestMember")
  createdContribs   Contribution[]      @relation("ContributionActor")
  createdWithdraws  Withdrawal[]        @relation("WithdrawalActor")
  createdRequests   EmergencyRequest[]  @relation("EmergencyDecisionActor")
  transactions      Transaction[]       @relation("TransactionMember")
  actedTransactions Transaction[]       @relation("TransactionActor")
  uploadedStatements BankStatement[]
  uploadedDocuments GoverningDocument[]
  sessions          Session[]
  accounts          Account[]
  resetTokens       PasswordResetToken[]
}

model Contribution {
  id               String   @id @default(cuid())
  memberId         String
  member           User     @relation("ContributionMember", fields: [memberId], references: [id])
  amount           Decimal  @db.Decimal(12, 2)
  contributionDate DateTime
  createdById      String?
  createdBy        User?    @relation("ContributionActor", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Withdrawal {
  id             String   @id @default(cuid())
  memberId       String
  member         User     @relation("WithdrawalMember", fields: [memberId], references: [id])
  amount         Decimal  @db.Decimal(12, 2)
  reason         String
  withdrawalDate DateTime
  createdById    String?
  createdBy      User?    @relation("WithdrawalActor", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EmergencyRequest {
  id          String          @id @default(cuid())
  memberId    String
  member      User            @relation("EmergencyRequestMember", fields: [memberId], references: [id])
  amount      Decimal         @db.Decimal(12, 2)
  reason      String
  status      EmergencyStatus @default(PENDING)
  requestDate DateTime        @default(now())
  decisionDate DateTime?
  decidedById String?
  decidedBy   User?           @relation("EmergencyDecisionActor", fields: [decidedById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Transaction {
  id         String          @id @default(cuid())
  memberId   String
  member     User            @relation("TransactionMember", fields: [memberId], references: [id])
  type       TransactionType
  amount     Decimal         @db.Decimal(12, 2)
  eventDate  DateTime
  notes      String?
  actorId    String?
  actor      User?           @relation("TransactionActor", fields: [actorId], references: [id])
  createdAt  DateTime        @default(now())
}

model BankStatement {
  id            String        @id @default(cuid())
  filename      String
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String
  statementType StatementType
  statementDate DateTime?
  statementPeriod String?
  uploadedById  String?
  uploadedBy    User?         @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime      @default(now())
}

model GoverningDocument {
  id           String   @id @default(cuid())
  title        String
  filename     String
  originalName String
  mimeType     String
  storagePath  String
  isActive     Boolean  @default(true)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
