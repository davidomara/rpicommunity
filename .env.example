DATABASE_URL="sqlserver://HOST:PORT;database=DB_NAME;user=USERNAME;password=PASSWORD;encrypt=true;trustServerCertificate=true;"

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"
APP_URL="https://rpicommunityapp.up.railway.app"
NEXT_PUBLIC_APP_URL="https://rpicommunityapp.up.railway.app"
AUTH_URL="https://rpicommunityapp.up.railway.app/api/auth"
NEXTAUTH_URL="https://rpicommunityapp.up.railway.app/api/auth"
UPLOAD_ROOT="./storage/private"
RESEND_API_KEY=""
RESET_EMAIL_FROM="RPIC Community <no-reply@example.com>"
