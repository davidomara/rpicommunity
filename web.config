<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="NextCommunityProxy" stopProcessing="true">
          <match url="^community($|/.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:0}" appendQueryString="true" />
        </rule>

        <!-- your existing ASP.NET rewrite rules stay below -->
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
